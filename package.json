{
  "name": "ink-file-picker",
  "version": "0.1.0",
  "description": "Filesystem navigation and file selection component for Ink",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ink": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "dependencies": {
    "figures": "^6.1.0",
    "picomatch": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/picomatch": "^3.0.0",
    "@types/react": "^18.3.0",
    "ink": "^5.0.0",
    "ink-testing-library": "^4.0.0",
    "react": "^18.3.0",
    "tsup": "^8.5.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
